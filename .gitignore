# ---- EXCEPTIONS ----

# config text files and samplesheets in pipeline
!pipeline/configs/**/*.txt
!pipeline/configs/**/*.tsv

# readme files
!readme.md
!**/readme.md

# key analysis notebooks
!analysis/figures.ipynb
!analysis/reporter_assays/reporter_assays.ipynb
!analysis/sqtl_bench/sqtl_benchmark_analysis.ipynb
!analysis/explain/analysis.ipynb
!analysis/dists/dists.ipynb
!analysis/test/figures_v2.ipynb

# specific analysis data
!analysis/fine_map/tabix_ftp_paths.tsv

# reporter assay scripts
!analysis/reporter_assays/scripts/score_*.py
!analysis/reporter_assays/mfass/prepare_dataset.py
!analysis/reporter_assays/vex_seq/prepare_dataset.py
analysis/reporter_assays/scripts/*.sbatch

# model weights to track (cls + reg, no sigmoid)
!models/*_cls_best.keras
!models/*_reg_best.keras

# models/ — ignore scripts for now
models/*.py

# pipeline — ignore for now
pipeline/scripts/
pipeline/__init__.py
pipeline/splaire_data.yml
pipeline/configs/splits_config.template.yaml

# pipeline reference — only track specific files
!pipeline/reference/GRCh38/getReference.py
!pipeline/reference/GRCh38/paralogs_GRCh38.txt.gz
pipeline/reference/GRCh38/gencode.v45.rRNA.interval_list
pipeline/reference/GRCh38/gencode.v45.refFlat.txt.bak
