
def referenceDir     = "${projectDir}/reference/GRCh38"
def defaultCondaEnv  = System.getenv('SPLAIRE_CONDA_ENV') ?: "${projectDir}/../envs/splaire_env.yml"

manifest {
  mainScript = 'main.nf'
}

conda {
  enabled = true
}


params.slurm = [
    queue: 'short',

    // alignment jobs
    align_cpus: 4,
    align_memory: '48 GB',
    align_time: '12h',

    // annotation jobs
    annot_cpus: 2,
    annot_memory: '8 GB',
    annot_time: '8h',

    // dataset jobs
    data_cpus: 2,
    data_memory: '16 GB',
    data_time: '12h'
]

process {
    executor = 'local'
    errorStrategy = { task.exitStatus in [137, 140, 141] ? 'retry' : 'terminate' }
    maxRetries = 2
    scratch = true
    conda = defaultCondaEnv

    cpus = 4
    memory = '16 GB'
    time = '4h'
}



params {
    samplesheet        = null
    vcf                = null
    input_matrix       = null
    input_variants     = null
    splits_config      = "${projectDir}/splits_config.yaml"

    genome_fasta       = "${referenceDir}/GRCh38.primary_assembly.genome.fa"
    genome_gtf         = "${referenceDir}/gencode.v45.primary_assembly.annotation.gtf"
    refflat            = "${referenceDir}/gencode.v45.refFlat.txt"
    rrna_intervals     = "${referenceDir}/gencode.v45.rRNA.interval_list"
    // note: generate refflat and rrna_intervals with scripts/make_picard_refs.sh
    gene_regions_bed   = "${referenceDir}/protein_coding_genes.bed"
    gene_regions_tsv   = "${referenceDir}/protein_coding_genes.tsv"
    paralogs_file      = "${referenceDir}/paralogs_GRCh38.txt.gz"
    star_genome_dir    = "${projectDir}/STAR_index"

    output_dir         = "${projectDir}/out"

    make_star_index    = false
    filter_vcf         = true

    threads            = 6
    regtools_args      = "-a 5 -m 20 -M 1000000 -s XS"
    spliser_path       = "${projectDir}/SpliSER/SpliSER_v0_1_8_pysam.py"
    spliser_process_args = ""

    // matrix settings
    matrix_output        = "splicing_matrix.tsv"
    matrix_denom_thresh  = 5.0  // coverage < this gets masked as 777

    // row filtering: min valid (non-0, non-777) values required in both SSU columns
    tx_row_filter        = 2

    // no --runThreadN here - set in module with ${task.cpus}
    star_align_params = "--outFilterType BySJout --outFilterMultimapNmax 20 --alignSJoverhangMin 5 --outSJfilterCountUniqueMin 100 1 1 1 --outSJfilterReads Unique --alignSJDBoverhangMin 1 --limitSjdbInsertNsj 5000000 --outFilterMismatchNmax 999 --outFilterMismatchNoverReadLmax 0.04 --alignIntronMin 20 --alignIntronMax 1000000 --alignMatesGapMax 1000000 --waspOutputMode SAMtag --outSAMattributes NH HI AS nM XS vW --outSAMtype BAM SortedByCoordinate --outSAMstrandField intronMotif --outSAMunmapped Within"
}


// logging
params.logs_dir = "${params.output_dir}/logs"

timeline {
    enabled = true
    file = "${params.logs_dir}/timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${params.logs_dir}/report.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${params.logs_dir}/trace.txt"
    overwrite = true
}

executor {
    queueSize = 100
    submitRateLimit = '20/1s'
}




profiles {
    standard {
        process.executor = 'local'
    }

    slurm {
        process.executor = 'slurm'
        process.queue = params.slurm.queue

        process {
            withName: 'ALIGN_PASS1|ALIGN_PASS2' {
                cpus = params.slurm.align_cpus
                memory = params.slurm.align_memory
                time = params.slurm.align_time
            }

            withName: 'FILTER_VCF' {
                cpus = params.slurm.annot_cpus
                memory = params.slurm.annot_memory
                time = params.slurm.annot_time
                scratch = false  // writes ~25GB VCF, local scratch too small
            }

            withName: 'COLLECT_SITES|FILL_SSU|ANNOTATE_SSU|EXTRACT_VARIANTS|MERGE_VARIANTS|MAKE_MATRIX|FILTER_EMPTY_TXS|FILL_GENCODE' {
                cpus = params.slurm.annot_cpus
                memory = params.slurm.annot_memory
                time = params.slurm.annot_time
            }

            withName: 'GENERATE_SPLITS|BUILD_H5|COMBINE_H5' {
                cpus = params.slurm.data_cpus
                memory = params.slurm.data_memory
                time = params.slurm.data_time
            }

            withName: 'STAR_GENOME_INDEX' {
                cpus = 8
                memory = '64 GB'
                time = '24h'
            }
        }
    }
}
